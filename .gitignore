# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep the example committed, ignore the rest)
.env*
!.env.example

# vercel
.vercel

# wrangler / cloudflare
.wrangler

# supabase (local only; keep migrations + config.toml)
/supabase/.temp
/supabase/.branches

# typescript
*.tsbuildinfo
next-env.d.ts
/dist/

# AI assistant / agent instructions (local, not part of the shipped repo)
CLAUDE.md
AGENTS.md
.claude/
