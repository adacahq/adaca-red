# ── Supabase ────────────────────────────────────────────────
# Public values — safe to ship to the browser. RLS protects the data,
# not the key. Use the project's anon (or publishable) key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only secret — NEVER expose to the browser or prefix with VITE_.
# Only needed for admin scripts / service tasks, not the app runtime.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Auth (Microsoft SSO) ────────────────────────────────────
# Comma-separated email domains permitted to sign in. Enforced in /auth/callback.
# (Not secret — VITE_ prefix so it resolves in the vinext/Vite build. Empty =
# allow any domain.)
VITE_ALLOWED_EMAIL_DOMAINS=adaca.com

# ── Email (Resend) ──────────────────────────────────────────
# Transactional app email — server-only. SSO means Supabase sends no auth mail.
RESEND_API_KEY=YOUR-RESEND-API-KEY
EMAIL_FROM=Adaca Red <ops@adaca.com>
